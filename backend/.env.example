DATABASE_URL=postgres://postgres:postgres@localhost:5432/dittoapp
DEBUG=true
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# GoWA (WhatsApp) — servicio en bot/docker-compose.yml
GOWA_BASE_URL=http://localhost:3000
# GOWA_DEVICE_ID=628123456789@s.whatsapp.net
GOWA_WEBHOOK_SECRET=secret

# API key opcional para POST /api/whatsapp/messages/send (n8n Cloud, etc.)
# WHATSAPP_API_KEY=mi-clave-secreta

# Webhook de n8n Cloud para flujos de conversación
# N8N_WEBHOOK_URL=https://tu-instancia.app.n8n.cloud/webhook/whatsapp-incoming
